---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CursorGlow from '../components/CursorGlow.astro';

const { title, date, category, excerpt, heroImage } = Astro.props;

// Format date safely
const formatDate = (dateStr) => {
  if (!dateStr) return null;
  try {
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return null;
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  } catch {
    return null;
  }
};

const formattedDate = formatDate(date);
---

<BaseLayout title={`Miau Studio | ${title}`}>
  <CursorGlow />
  <Nav />

  <article class="blog-post container">
    <a href="/#blog" class="back-link cursor-interact" data-cursor="VIEW">← Back to Blog</a>

    <header class="blog-header">
      <span class="blog-category">{category}</span>
      <h1 class="blog-title">{title}</h1>
      <p class="blog-excerpt">{excerpt}</p>
      {formattedDate && (
        <time class="blog-date">{formattedDate}</time>
      )}
    </header>

    {heroImage && (
      <div class="blog-hero-image">
        <div class="hero-image-frame">
          <img src={heroImage} alt={title} />
        </div>
      </div>
    )}

    <div class="blog-content">
      <slot />
    </div>

    <footer class="blog-footer">
      <div class="footer-cta">
        <h2>Ready to Skate?</h2>
        <p>Wishlist Skate Beats and be the first to know when we drop.</p>
        <a href="#game" class="btn btn-filled cursor-interact" data-cursor="WISHLIST">Wishlist Now</a>
      </div>
    </footer>
  </article>

  <Footer />
</BaseLayout>

<style>
  .blog-post {
    padding-top: clamp(80px, 15vw, 160px);
    padding-bottom: clamp(80px, 15vw, 160px);
    max-width: 800px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--pink);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: transform 0.2s ease;
  }

  .back-link:hover {
    transform: translateX(-5px);
  }

  .blog-header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .blog-category {
    display: inline-block;
    background: var(--yellow);
    color: var(--black);
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .blog-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .blog-excerpt {
    font-size: 1.25rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .blog-date {
    display: block;
    font-size: 0.9rem;
    color: #888;
    font-weight: 500;
  }

  .blog-hero-image {
    margin: 3rem 0;
    width: 100%;
  }

  .hero-image-frame {
    width: 100%;
    border: 3px solid var(--black);
    border-radius: 8px;
    overflow: hidden;
    background: var(--yellow);
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .hero-image-frame::before {
    content: '🖼️';
    position: absolute;
    font-size: 4rem;
    opacity: 0.5;
    z-index: 1;
  }

  .hero-image-frame img {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 2;
  }

  .hero-image-frame:empty::after {
    content: 'Blog Hero Image';
    position: absolute;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--black);
    opacity: 0.3;
    z-index: 1;
  }

  .blog-content {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--black);
  }

  .blog-content :global(h2) {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
    display: block;
    width: 100%;
  }

  .blog-content :global(h3) {
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
    display: block;
    width: 100%;
  }

  .blog-content :global(p) {
    margin-bottom: 2rem;
    display: block;
    width: 100%;
  }

  .blog-content :global(strong) {
    font-weight: 800;
    color: var(--pink);
  }

  .blog-content :global(em) {
    font-style: italic;
    color: var(--blue);
  }

  .blog-content :global(a) {
    color: var(--pink);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .blog-content :global(a:hover) {
    color: var(--blue);
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: 2rem;
    margin-top: 2rem;
    padding-left: 2rem;
  }

  .blog-content :global(li) {
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .blog-content :global(code) {
    background: var(--yellow);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.9em;
  }

  .blog-content :global(blockquote) {
    border-left: 4px solid var(--pink);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    font-size: 1.25rem;
    color: #666;
  }

  .blog-footer {
    margin-top: 6rem;
    padding-top: 4rem;
    border-top: 2px solid var(--black);
  }

  .footer-cta {
    text-align: center;
  }

  .footer-cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    display: block;
    width: 100%;
    text-align: center;
  }

  .footer-cta p {
    font-size: 1.125rem;
    color: #666;
    margin-bottom: 3rem;
    margin-top: 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    display: block;
    width: 100%;
    text-align: center;
  }

  .footer-cta .btn {
    display: inline-block;
    width: auto;
  }

  @media (max-width: 768px) {
    .blog-post {
      padding-top: 60px;
      padding-bottom: 60px;
    }

    .blog-content {
      font-size: 1rem;
    }

    .footer-cta h2 {
      font-size: 1.5rem;
    }

    .footer-cta p {
      font-size: 1rem;
    }

    .footer-cta .btn {
      width: 100%;
      max-width: 320px;
    }

    .hero-image-frame {
      min-height: 250px;
      border: 2px solid var(--black);
    }

    .hero-image-frame::before {
      font-size: 2.5rem;
    }
  }
</style>

<script>
  // Smooth scroll back to blog section
  document.querySelector('.back-link')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.location.href = '/#blog';
  });
</script>
