---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="canonical" href="https://miaustudios.creative">
    <meta name="description" content="Miau Studios - A creative studio turning digital comfort food into visceral experiences. We play hard, we make games harder.">
    <meta property="og:title" content="{title}">
    <meta property="og:description" content="A creative studio turning digital comfort food into visceral experiences.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://miaustudios.creative">
    <meta property="og:image" content="https://miaustudios.creative/miau-logo.svg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{title}">
    <meta name="twitter:description" content="A creative studio turning digital comfort food into visceral experiences.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;800&display=swap" rel="stylesheet">
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
