---
---

<section id="blog" class="blog">
  <div class="container blog-container">
    <div class="blog-header">
      <div class="section-label">THE STORIES</div>
      <h2 class="display-text reveal-split">Latest Stories</h2>
      <div class="filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="development">Development</button>
        <button class="filter-btn" data-filter="sound-design">Sound Design</button>
        <button class="filter-btn" data-filter="art-direction">Art Direction</button>
      </div>
    </div>
    <img
      src="/miau-logo.svg"
      class="easter-cat blog-cat"
      alt=""
      aria-hidden="true"
    />
    <div class="grid-3 reveal-stagger blog-grid">
      <!-- BEHIND THE BEAT CARD -->
      <a
        href="/blog/behind-the-beat"
        class="interactive-card blog-card card-yellow cursor-interact"
        data-category="development"
        data-cursor="READ"
      >
        <div class="blog-thumbnail">
          <div class="placeholder-content">🎮 🎵 🛹</div>
        </div>
        <div class="blog-info">
          <div class="card-spotlight"></div>
          <span class="tag-pill">Development</span>
          <h3>Behind the Beat: How Skate Beats Was Born</h3>
          <p>
            The story of how two animators accidentally created the most unhinged rhythm skating game ever made.
          </p>
          <div class="read-more">Read more <span>→</span></div>
        </div>
      </a>

      <!-- SOUND DESIGN CARD -->
      <a
        href="/blog/sound-design-secrets"
        class="interactive-card blog-card card-pink cursor-interact"
        data-category="sound-design"
        data-cursor="READ"
      >
        <div class="blog-thumbnail">
          <div class="placeholder-content">🎧 🎶 💿</div>
        </div>
        <div class="blog-info">
          <div class="card-spotlight"></div>
          <span class="tag-pill tag-pink">Sound Design</span>
          <h3>Why Your Bassline Matters</h3>
          <p>
            Deep dive into how Skate Beats transforms your music library into playable levels.
          </p>
          <div class="read-more">Read more <span>→</span></div>
        </div>
      </a>

      <!-- NEON ART CARD -->
      <a
        href="/blog/neon-art-direction"
        class="interactive-card blog-card card-blue cursor-interact"
        data-category="art-direction"
        data-cursor="READ"
      >
        <div class="blog-thumbnail">
          <div class="placeholder-content">🎨 💛 🌆</div>
        </div>
        <div class="blog-info">
          <div class="card-spotlight"></div>
          <span class="tag-pill tag-yellow-black">Art Direction</span>
          <h3>Neon Dreams: The Art Direction of Skate Beats</h3>
          <p>
            Why we chose a cyberpunk aesthetic and how we make it pop without melting your GPU.
          </p>
          <div class="read-more">Read more <span>→</span></div>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .blog-cat {
    position: absolute;
    bottom: 36px;
    right: 36px;
    width: 36px;
    height: 36px;
    opacity: 0.3;
    transition: opacity 0.3s ease,
      transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .blog-cat:hover {
    opacity: 1;
    transform: rotate(360deg);
  }

  .blog {
    background: var(--white);
    position: relative;
    z-index: 10000;
  }

  .blog-container {
    position: relative;
    z-index: 10001;
  }

  .blog-header {
    margin-bottom: 3rem;
    position: relative;
    z-index: 10001;
  }

  h2 {
    font-size: 3.5rem;
    margin-bottom: 2rem;
  }

  .filters {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    background: none;
    border: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.1rem;
    color: #888;
    cursor: pointer;
    position: relative;
    padding: 4px 0;
    transition: color 0.3s;
  }

  .filter-btn.active {
    color: var(--black);
  }

  .filter-btn::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--pink);
    transition: width 0.3s;
  }

  .filter-btn.active::after {
    width: 100%;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    position: relative;
    z-index: 10001;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--black);
    background: var(--white);
    height: 100%;
    padding: 0;
    overflow: hidden;
    border: var(--border);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s,
      scale 0.4s, box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: none;
    position: relative;
  }

  .blog-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .blog-thumbnail {
    height: 180px;
    width: 100%;
    background: #f8f8f8;
    border-bottom: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-content {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: #888;
    font-weight: 700;
  }

  .blog-info {
    padding: 2.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .tag-pill {
    background: var(--blue);
    color: var(--white);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: inline-block;
    align-self: flex-start;
    transition: transform 0.3s;
  }

  .tag-pink {
    background: var(--pink);
  }
  .tag-yellow-black {
    background: var(--yellow);
    color: var(--black);
  }

  h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  p {
    color: #555;
    margin-bottom: 2rem;
    flex-grow: 1; /* Pushes read-more to bottom */
  }

  .read-more {
    font-weight: 700;
    color: var(--pink);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto; /* Pin to bottom */
  }

  .read-more span {
    transition: transform 0.3s;
  }

  .blog-card:hover .read-more span {
    transform: translateX(4px);
  }

  .blog-card:hover .tag-pill {
    transform: translateY(-4px);
  }

  :global(.blog-card.hidden) {
    opacity: 0;
    scale: 0.95;
    pointer-events: none;
    position: absolute; /* Hide from layout */
    width: 0;
    height: 0;
    overflow: hidden;
  }

  @media (max-width: 1024px) {
    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .grid-3 {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .filters {
      /* Renamed to .blog-filters in the instruction, but keeping original to avoid HTML changes */
      overflow-x: auto;
      flex-wrap: nowrap;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 8px; /* room for scroll indicator if browser shows it */
      scrollbar-width: none;
      justify-content: flex-start;
      width: 100%;
    }

    .filters::-webkit-scrollbar {
      /* Renamed to .blog-filters in the instruction, but keeping original to avoid HTML changes */
      display: none;
    }

    .filter-btn {
      flex-shrink: 0;
    }
  }
</style>

<script>
  // Blog Filters
  const filterBtns = document.querySelectorAll(".filter-btn");
  const blogCards = document.querySelectorAll(".blog-card");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      // Toggle active states
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      const category = btn.getAttribute("data-filter");

      blogCards.forEach((card) => {
        const cardCategory = card.getAttribute("data-category");
        if (category === "all" || cardCategory === category) {
          card.classList.remove("hidden");
        } else {
          card.classList.add("hidden");
        }
      });
    });
  });
</script>
