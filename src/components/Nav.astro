---
<nav id="main-nav">
  <div class="nav-inner">
    <div class="nav-logo">MIAU STUDIO</div>
    <button class="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <div class="nav-links" id="nav-links">
    <a href="#about">About</a>
    <a href="#game">Skate Beats</a>
    <a href="#team">Team</a>
  </div>
</nav>

<style>
  #main-nav {
    position: fixed;
    top: 0;
    left: 50%;
    width: 100%;
    transform: translateX(-50%) translateY(0);
    padding: 2rem var(--padding-x);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1000;
    mix-blend-mode: difference;
    color: var(--white);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .nav-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.05em;
  }

  .nav-links {
    display: flex;
    gap: 3rem;
  }

  .nav-links a {
    color: inherit;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    position: relative;
    padding-bottom: 5px;
  }

  .hamburger {
    display: none;
  }

  /* PILL STATE */
  :global(#main-nav.nav-pill) {
    top: 20px;
    width: calc(100% - 40px);
    max-width: 800px;
    border-radius: 999px;
    border: var(--border);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 2px 0; /* padding handled by nav-inner */
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    mix-blend-mode: normal !important;
    color: var(--black) !important;
  }
  
  :global(#main-nav.nav-pill .nav-inner) {
    padding: 10px 30px;
  }

  :global(#main-nav.nav-hidden) {
    transform: translateX(-50%) translateY(-150%);
  }

  @media (min-width: 769px) {
    .nav-inner {
        width: auto;
        gap: 2rem;
    }
    .nav-inner {
        justify-content: flex-start;
    }
    #main-nav {
        justify-content: space-between;
    }
    .hamburger {
        display: none !important;
    }
  }

  @media (max-width: 768px) {
    #main-nav {
      position: fixed;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
      width: calc(100% - 32px);
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid #000;
      border-radius: 999px;
      z-index: 1000;
      overflow: hidden;
      transition: border-radius 0.3s ease, transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.4s ease;
      display: block;
      padding: 0;
      mix-blend-mode: normal;
      color: #000;
    }

    #main-nav.menu-open {
      border-radius: 20px;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 20px;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      padding: 8px 20px 16px;
      gap: 0;
      border-top: 1px solid rgba(0,0,0,0.1);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links a {
      padding: 12px 0;
      font-family: "Montserrat", sans-serif;
      font-weight: 600;
      font-size: 16px;
      color: #000;
      text-decoration: none;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }

    .nav-links a:last-child {
      border-bottom: none;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 24px;
      height: 24px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
    }

    .hamburger span {
      display: block;
      width: 100%;
      height: 2px;
      background: #000;
      border-radius: 2px;
      transition: transform 0.3s ease, opacity 0.3s ease;
      transform-origin: center;
    }

    .hamburger.open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .hamburger.open span:nth-child(2) {
      opacity: 0;
    }

    .hamburger.open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script src="../scripts/nav.js"></script>
