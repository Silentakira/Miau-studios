---
---
<section id="community" class="community">
  <div class="container community-container">
    <h2 class="display-text reveal-split">Come hang with us</h2>
    <p>We build in public, share the process, and actually talk to our players. Join the community.</p>
    <div class="community-actions">
      <div class="magnet-wrap">
        <a href="#" class="btn btn-filled magnetic cursor-interact" data-cursor="VIEW"
           style="background: var(--black); color: var(--white); border-color: var(--black);">
           Join Discord
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .community {
    text-align: center;
    background-color: transparent;
    transition: background-color 0.8s ease;
  }

  :global(.community.active-bg) {
    background-color: var(--yellow);
  }

  h2 {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
  }

  p {
    font-size: 1.25rem;
    max-width: 600px;
    margin: 0 auto 3rem;
    color: #444;
  }

  .community-actions {
      display: flex;
      justify-content: center;
  }

  @media (max-width: 768px) {
    .community {
      padding-block: 80px;
    }

    .community-actions {
      flex-direction: column;
      align-items: center;
      gap: 12px;
      width: 100%;
    }

    .community-actions .magnet-wrap,
    .community-actions a {
      width: 100%;
      max-width: 320px;
    }
  }
</style>
