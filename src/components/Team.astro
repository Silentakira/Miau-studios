---
---
<section id="team" class="team container">
  <div class="team-header">
    <div class="section-label">The Minds</div>
    <h2 class="team-subtitle reveal-split">Crackheads</h2>
  </div>
  <div class="team-grid reveal-stagger">
    <div class="profile">
      <div class="profile-img-wrap profile-akira cursor-interact" data-cursor="VIEW">
          <div class="placeholder-label">Akira</div>
      </div>
      <h4>Akira</h4>
      <p>Art Director & Animator</p>
    </div>
    <div class="profile">
      <div class="profile-img-wrap profile-joana cursor-interact" data-cursor="VIEW">
          <div class="placeholder-label">Joana</div>
      </div>
      <h4>Joana</h4>
      <p>Lead Animator & Chaos Engine</p>
    </div>
  </div>
</section>

<style>
  .team {
    padding-top: clamp(100px, 15vw, 200px);
    padding-bottom: clamp(100px, 15vw, 200px);
    text-align: center;
  }

  .team-header {
    max-width: 800px;
    margin: 0 auto 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-label {
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: #888;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .team-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    color: var(--pink);
    margin-bottom: 4rem;
    width: 100%;
    text-align: center;
  }

  .team-subtitle :global(.split-top),
  .team-subtitle :global(.split-bottom) {
    display: flex;
    justify-content: center;
  }

  .team-grid {
    display: flex;
    justify-content: center;
    gap: 6rem;
    flex-wrap: wrap;
  }

  .profile {
    text-align: center;
  }

  .profile-img-wrap {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    margin: 0 auto 2rem;
    background: #eee;
    border: var(--border);
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible; /* To allow ring to pulse outside */
  }

  .placeholder-label {
      font-size: 0.75rem;
      font-weight: 700;
      color: #888;
      text-transform: uppercase;
  }

  .profile-img-wrap::after {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    z-index: -1;
    box-shadow: 0 0 0 0 transparent;
    pointer-events: none;
    transition: box-shadow 0.3s ease;
  }

  /* Pulse Rings */
  @media (prefers-reduced-motion: no-preference) {
    .profile-akira:hover::after,
    .profile-akira.pulse-active::after {
      animation: pulseRingPink 1.5s infinite;
    }
    .profile-joana:hover::after,
    .profile-joana.pulse-active::after {
      animation: pulseRingBlue 1.5s infinite;
    }
  }

  @keyframes pulseRingPink {
    0% { box-shadow: 0 0 0 0 rgba(253, 130, 203, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(253, 130, 203, 0); }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  @keyframes pulseRingBlue {
    0% { box-shadow: 0 0 0 0 rgba(77, 186, 253, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(77, 186, 253, 0); }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .profile h4 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .profile p {
    color: #666;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .team-grid {
      flex-direction: column;
      align-items: center;
      gap: 48px;
    }

    .profile-img-wrap {
      width: 140px;
      height: 140px;
    }

    .profile h4 {
        font-size: 1.5rem;
    }
  }
</style>

<script>
    // Pulse ring on tap for mobile
    const isTouchDevice = window.matchMedia('(hover: none)').matches;
    if (isTouchDevice) {
        document.querySelectorAll('.profile-img-wrap').forEach(el => {
            el.addEventListener('touchstart', () => {
                el.classList.add('pulse-active');
                setTimeout(() => el.classList.remove('pulse-active'), 1500);
            });
        });
    }
</script>
