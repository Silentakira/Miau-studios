---
---
<section id="team" class="team-section container">
  <div class="team-header">
    <div class="section-label">THE MINDS</div>
    <h2 class="team-subtitle">Crackheads</h2>
  </div>
  <div class="team-profiles reveal-stagger">
    <div class="team-profile">
      <div class="profile-circle profile-img-wrap profile-akira cursor-interact" data-cursor="VIEW">
          <img src="/akira-profile.jpg" alt="Akira - Art Director & Animator" class="profile-img" />
      </div>
      <h4 class="profile-name">Akira</h4>
      <p class="profile-role">Art Director & Animator</p>
    </div>
    <div class="team-profile">
      <div class="profile-circle profile-img-wrap profile-joana cursor-interact" data-cursor="VIEW">
          <img src="/joana-profile.jpg" alt="Joana - Lead Animator & Chaos Engine" class="profile-img" />
      </div>
      <h4 class="profile-name">Joana</h4>
      <p class="profile-role">Lead Animator & Chaos Engine</p>
    </div>
  </div>
</section>

<style>
  .team-section {
    padding-top: clamp(100px, 15vw, 200px);
    padding-bottom: clamp(100px, 15vw, 200px);
    text-align: center;
  }

  .team-header {
    max-width: 800px;
    margin: 0 auto 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .team-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    color: var(--pink);
    margin-bottom: 2rem;
    width: 100%;
    text-align: center;
    font-weight: 700;
  }

  .team-profiles {
    display: flex;
    justify-content: center;
    gap: 6rem;
    flex-wrap: wrap;
  }

  .team-profile {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .profile-circle {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    margin: 0 auto 2rem;
    background: #eee;
    border: var(--border);
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  .profile-circle::after {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    z-index: -1;
    box-shadow: 0 0 0 0 transparent;
    pointer-events: none;
    transition: box-shadow 0.3s ease;
  }

  /* Pulse Rings */
  @media (prefers-reduced-motion: no-preference) {
    .profile-akira:hover::after,
    .profile-akira.pulse-active::after {
      animation: pulseRingPink 1.5s infinite;
    }
    .profile-joana:hover::after,
    .profile-joana.pulse-active::after {
      animation: pulseRingBlue 1.5s infinite;
    }
  }

  @keyframes pulseRingPink {
    0% { box-shadow: 0 0 0 0 rgba(253, 130, 203, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(253, 130, 203, 0); }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  @keyframes pulseRingBlue {
    0% { box-shadow: 0 0 0 0 rgba(77, 186, 253, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(77, 186, 253, 0); }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .profile-name {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    font-weight: 800;
    color: var(--black);
    text-align: center;
    display: block;
    width: 100%;
  }

  .profile-role {
    color: #666;
    font-weight: 500;
    text-align: center;
    display: block;
    width: 100%;
  }

  @media (max-width: 768px) {
    .team-section {
      text-align: center;
      padding-inline: var(--padding-x);
    }

    .team-header {
      margin-bottom: 48px;
    }

    .section-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #000;
      margin-bottom: 8px;
    }

    .team-subtitle {
      display: block;
      font-size: clamp(28px, 8vw, 48px);
      color: #FD82CB;
      font-weight: 700;
      margin-bottom: 0;
    }

    .team-profiles {
      flex-direction: column;
      align-items: center;
      gap: 56px;
    }

    .team-profile {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      width: 100%;
    }

    .profile-circle {
      width: 160px;
      height: 160px;
      flex-shrink: 0;
      margin-bottom: 0;
    }

    .profile-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 50%;
    }

    .profile-name {
      font-size: clamp(24px, 6vw, 32px);
      font-weight: 800;
      margin: 0;
      text-align: center;
      display: block;
      width: 100%;
      color: var(--black);
    }

    .profile-role {
      font-size: 14px;
      color: #666;
      margin: 0;
      text-align: center;
      display: block;
      width: 100%;
      font-weight: 500;
    }
  }
</style>

<script>
    // Pulse ring on tap for mobile
    const isTouchDevice = window.matchMedia('(hover: none)').matches;
    if (isTouchDevice) {
        document.querySelectorAll('.profile-img-wrap').forEach(el => {
            el.addEventListener('touchstart', () => {
                el.classList.add('pulse-active');
                setTimeout(() => el.classList.remove('pulse-active'), 1500);
            });
        });
    }
</script>
