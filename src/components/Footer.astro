<footer class="dark-section">
  <div class="marquee-wrap">
    <div class="marquee">
      <span>Digital comfort food.</span><span class="yellow-txt"
        >Secretly feral.</span
      >
      <span>Digital comfort food.</span><span class="yellow-txt"
        >Secretly feral.</span
      >
      <span>Digital comfort food.</span><span class="yellow-txt"
        >Secretly feral.</span
      >
      <span>Digital comfort food.</span><span class="yellow-txt"
        >Secretly feral.</span
      >
    </div>
  </div>
  <img
    src="/miau-logo.svg"
    class="easter-cat footer-cat"
    alt=""
    aria-hidden="true"
  />
  <div class="footer-middle container">
    <a
      href="#"
      class="social-link cursor-interact"
      data-cursor="VIEW"
      data-emoji="📸">Instagram</a
    >
    <a
      href="#"
      class="social-link cursor-interact"
      data-cursor="VIEW"
      data-emoji="🎵">TikTok</a
    >
    <a
      href="#"
      class="social-link cursor-interact"
      data-cursor="VIEW"
      data-emoji="🐦">Twitter</a
    >
    <a
      href="#"
      class="social-link cursor-interact"
      data-cursor="VIEW"
      data-emoji="🎮">Discord</a
    >
  </div>

  <div class="footer-bottom">
    <div class="footer-logo">MIAU</div>
    <div class="copyright">© 2026 Miau Studio</div>
  </div>
</footer>

<style>
  .footer-cat {
    position: absolute;
    bottom: 20px;
    left: clamp(40px, 8vw, 120px);
    width: 80px;
    height: 80px;
    opacity: 0.15;
    filter: invert(1);
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: catFloat 4s ease-in-out infinite;
  }

  @keyframes catFloat {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-10px) rotate(5deg);
    }
  }

  .footer-cat:hover {
    opacity: 0.4;
    filter: invert(1) drop-shadow(0 0 20px rgba(255, 225, 0, 0.6));
    animation: catSpin 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes catSpin {
    0% {
      transform: translateY(0) rotate(0deg) scale(1);
    }
    50% {
      transform: translateY(-15px) rotate(180deg) scale(1.1);
    }
    100% {
      transform: translateY(0) rotate(360deg) scale(1);
    }
  }
  footer {
    background: var(--black);
    color: var(--white);
    overflow: hidden;
    position: relative;
    padding: 0;
  }

  .marquee-wrap {
    padding: 3rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    display: flex;
    white-space: nowrap;
    touch-action: pan-y;
    width: 100%;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .marquee-wrap:hover {
    opacity: 0.9;
  }

  .marquee {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    text-transform: uppercase;
    display: flex;
    line-height: 1.1;
    transition: animation-duration 0.3s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .marquee {
      animation: marquee 25s linear infinite;
    }

    .marquee-wrap:hover .marquee {
      animation-duration: 15s;
    }
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .marquee span {
    margin-right: 2rem;
    display: inline-block;
    overflow-wrap: break-word;
  }

  .yellow-txt {
    color: var(--yellow);
  }

  .footer-middle {
    padding: 8rem 0;
    display: flex;
    justify-content: center;
    gap: 4rem;
  }

  .social-link {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 3rem);
    font-weight: 800;
    color: var(--white);
    text-decoration: none;
    position: relative;
    display: inline-block;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: none;
  }

  .social-link::before {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, var(--yellow), var(--pink));
    transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    border-radius: 2px;
  }

  .social-link:hover::before {
    width: 100%;
  }

  .social-link:hover {
    color: var(--pink);
    transform: translateY(-20px) rotate(-3deg) scale(1.05);
    text-shadow: 0 0 20px rgba(253, 130, 203, 0.5);
  }

  :global(.floating-emoji) {
    position: absolute;
    left: 50%;
    bottom: 100%;
    transform: translateX(-50%);
    font-size: 2rem;
    pointer-events: none;
    z-index: 10;
    animation: floatUpEmoji 0.6s forwards;
  }

  @keyframes floatUpEmoji {
    0% {
      transform: translate(-50%, 0);
      opacity: 1;
    }
    100% {
      transform: translate(-50%, -40px) scale(1.2);
      opacity: 0;
    }
  }

  .footer-bottom {
    padding: 2rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 12vw, 15rem);
    font-weight: 900;
    line-height: 0.75;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.03);
    pointer-events: none;
  }

  .copyright {
    color: #666;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  @media (max-width: 1024px) {
    .footer-middle {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .marquee {
      font-size: clamp(20px, 6vw, 32px);
      animation-duration: 12s;
      transform: translateZ(0); /* force GPU */
      backface-visibility: hidden;
      will-change: transform;
    }

    .marquee-wrap {
      pointer-events: none; /* stop touch events interfering */
      touch-action: pan-y;
    }

    .footer-main {
      padding-block: 60px;
    }

    .social-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      text-align: center;
      justify-items: center;
    }

    .brand-large {
      font-size: clamp(32px, 10vw, 60px);
      margin-top: 4rem;
    }

    .footer-bottom {
      padding: 2rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }
  }
</style>

<script>
  // Emoji Float
  document.querySelectorAll(".social-link").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      if (prefersReducedMotion) return;

      const emoji = link.getAttribute("data-emoji");
      if (!emoji) return;

      const span = document.createElement("span");
      span.className = "floating-emoji";
      span.innerText = emoji;
      link.appendChild(span);

      setTimeout(() => {
        if (span.parentNode) span.remove();
      }, 600);
    });
  });

  // Interactive Marquee
  const marqueeWrap = document.querySelector('.marquee-wrap');
  const marquee = document.querySelector('.marquee');

  if (marqueeWrap && marquee) {
    let isPaused = false;

    marqueeWrap.addEventListener('click', () => {
      isPaused = !isPaused;
      marquee.style.animationPlayState = isPaused ? 'paused' : 'running';

      // Visual feedback
      marqueeWrap.style.transform = 'scale(1.02)';
      setTimeout(() => {
        marqueeWrap.style.transform = 'scale(1)';
      }, 200);
    });

    // Speed up on scroll
    let lastScrollY = window.scrollY;
    window.addEventListener('scroll', () => {
      const delta = Math.abs(window.scrollY - lastScrollY);
      if (delta > 10 && !isPaused) {
        const currentDuration = 25 - Math.min(delta * 0.1, 15);
        marquee.style.animationDuration = `${currentDuration}s`;
      }
      lastScrollY = window.scrollY;
    }, { passive: true });
  }

  // Footer cat surprise
  const footerCat = document.querySelector('.footer-cat');
  let catClicks = 0;

  if (footerCat) {
    footerCat.addEventListener('click', () => {
      catClicks++;

      if (catClicks === 3) {
        // Surprise on 3rd click!
        footerCat.style.transform = 'scale(2) rotate(720deg)';
        footerCat.style.opacity = '0.8';
        footerCat.style.filter = 'invert(1) drop-shadow(0 0 30px rgba(255, 225, 0, 0.8))';

        setTimeout(() => {
          footerCat.style.transform = '';
          footerCat.style.opacity = '';
          footerCat.style.filter = '';
          catClicks = 0;
        }, 1000);
      }
    });
  }
</script>
