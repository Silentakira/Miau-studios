---
<footer class="dark-section">
  <div class="marquee-wrap">
    <div class="marquee">
      <span>Digital comfort food.</span><span class="yellow-txt">Secretly feral.</span>
      <span>Digital comfort food.</span><span class="yellow-txt">Secretly feral.</span>
      <span>Digital comfort food.</span><span class="yellow-txt">Secretly feral.</span>
      <span>Digital comfort food.</span><span class="yellow-txt">Secretly feral.</span>
    </div>
  </div>

  <div class="footer-middle container">
    <a href="#" class="social-link cursor-interact" data-cursor="VIEW" data-emoji="📸">Instagram</a>
    <a href="#" class="social-link cursor-interact" data-cursor="VIEW" data-emoji="🎵">TikTok</a>
    <a href="#" class="social-link cursor-interact" data-cursor="VIEW" data-emoji="🐦">Twitter</a>
    <a href="#" class="social-link cursor-interact" data-cursor="VIEW" data-emoji="🎮">Discord</a>
  </div>

  <div class="footer-bottom">
    <div class="footer-logo">MIAU</div>
    <div class="copyright">© 2026 Miau Studio</div>
  </div>
</footer>

<style>
  footer {
    background: var(--black);
    color: var(--white);
    overflow: hidden;
    position: relative;
    padding: 0;
  }

  .marquee-wrap {
    padding: 3rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    display: flex;
    white-space: nowrap;
  }

  .marquee {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 900;
    text-transform: uppercase;
    display: flex;
  }

  @media (prefers-reduced-motion: no-preference) {
    .marquee {
      animation: marquee 25s linear infinite;
    }
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .marquee span {
    margin-right: 2rem;
  }

  .yellow-txt {
    color: var(--yellow);
  }

  .footer-middle {
    padding: 8rem 0;
    display: flex;
    justify-content: center;
    gap: 4rem;
  }

  .social-link {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 3rem);
    font-weight: 800;
    color: var(--white);
    text-decoration: none;
    position: relative;
    display: inline-block;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .social-link:hover {
    color: var(--pink);
    transform: translateY(-15px) rotate(-2deg);
  }

  :global(.floating-emoji) {
    position: absolute;
    left: 50%;
    bottom: 100%;
    transform: translateX(-50%);
    font-size: 2rem;
    pointer-events: none;
    z-index: 10;
    animation: floatUpEmoji 0.6s forwards;
  }

  @keyframes floatUpEmoji {
    0% { transform: translate(-50%, 0); opacity: 1; }
    100% { transform: translate(-50%, -40px) scale(1.2); opacity: 0; }
  }

  .footer-bottom {
    padding: 2rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 12vw, 15rem);
    font-weight: 900;
    line-height: 0.75;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.03);
    pointer-events: none;
  }

  .copyright {
    color: #666;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  @media (max-width: 1024px) {
    .footer-middle {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .marquee {
      font-size: clamp(20px, 6vw, 32px);
    }
    .marquee p {
        animation-duration: 12s; /* faster on mobile */
    }

    .footer-main {
      padding-block: 60px;
    }

    .social-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      text-align: center;
      justify-items: center;
    }

    .brand-large {
      font-size: clamp(32px, 10vw, 60px);
      margin-top: 4rem;
    }

    .footer-bottom {
        padding: 2rem;
        flex-direction: column;
        align-items: flex-start;
        gap: 2rem;
    }
  }
</style>

<script>
  // Emoji Float
  document.querySelectorAll('.social-link').forEach(link => {
    link.addEventListener('mouseenter', () => {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) return;

      const emoji = link.getAttribute('data-emoji');
      if (!emoji) return;

      const span = document.createElement('span');
      span.className = 'floating-emoji';
      span.innerText = emoji;
      link.appendChild(span);

      setTimeout(() => {
        if (span.parentNode) span.remove();
      }, 600);
    });
  });
</script>
