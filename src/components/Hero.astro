---
---

<header class="hero container">
  <div class="hero-bg">
    <div class="bg-shape hero-blob"></div>
    <div class="bg-shape hero-blob"></div>
    <div class="bg-shape"></div>
  </div>
  <h1 id="hero-headline" class="scramble-text glitch">
    <span class="text-hover-effect">Digital comfort food. Built with teeth.</span>
  </h1>

  <div class="hover-indicator">
    <div class="hover-arrow">↗</div>
    <div class="hover-text">hover here</div>
  </div>

  <p class="text-hover-effect">
    A creative studio turning digital comfort food into <span class="cycle-wrap"
      ><span class="cycle-word">visceral</span>
    </span> experiences. We play hard, we make games harder.
  </p>

  <div class="hero-actions">
    <div class="magnet-wrap">
      <a
        href="#about"
        class="btn btn-outline magnetic cursor-interact"
        data-cursor="VIEW">Discover More</a
      >
    </div>
    <div class="magnet-wrap">
      <a
        href="#game"
        class="btn btn-filled magnetic cursor-interact"
        data-cursor="WISHLIST">Wishlist the Game</a
      >
    </div>
  </div>

  <div class="social-proof">
    <svg
      width="12"
      height="12"
      viewBox="0 0 12 12"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <circle cx="6" cy="6" r="6" fill="#FD82CB"></circle>
    </svg>
    <span id="social-counter">0</span> people already wishlisted
  </div>
</header>

<style>
  .hero {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: visible;
    z-index: 1;
    padding-inline: var(--padding-x);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .bg-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.06;
  }

  .bg-shape:nth-child(1) {
    width: 60vw;
    height: 60vw;
    background: var(--yellow);
    top: -20%;
    left: -10%;
  }

  .bg-shape:nth-child(2) {
    width: 30vw;
    height: 30vw;
    background: var(--pink);
    top: 20%;
    right: 10%;
  }

  .bg-shape:nth-child(3) {
    width: 50vw;
    height: 50vw;
    background: var(--blue);
    bottom: -10%;
    right: -10%;
  }

  h1 {
    max-width: 1100px;
    margin-bottom: 2rem;
    min-height: 220px;
  }

  .glitch {
    position: relative;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .glitch::before {
    color: var(--pink);
    z-index: 2;
  }

  .glitch::after {
    color: var(--blue);
    z-index: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .glitch::before {
      animation: glitch-1 1.5s steps(2, end) forwards;
    }
    .glitch::after {
      animation: glitch-2 1.5s steps(3, end) forwards;
    }
    .bg-shape {
      animation: drift 20s infinite alternate ease-in-out;
    }
  }

  @keyframes glitch-1 {
    0% {
      clip-path: inset(20% 0 60% 0);
      transform: translate(-4px, 2px);
    }
    20% {
      clip-path: inset(70% 0 10% 0);
      transform: translate(3px, -2px);
    }
    40% {
      clip-path: inset(40% 0 40% 0);
      transform: translate(-2px, 3px);
    }
    60% {
      clip-path: inset(10% 0 80% 0);
      transform: translate(4px, -1px);
    }
    80% {
      clip-path: inset(50% 0 30% 0);
      transform: translate(-3px, 2px);
    }
    100% {
      clip-path: inset(0% 0 100% 0);
      transform: translate(0);
      opacity: 0;
    }
  }

  @keyframes glitch-2 {
    0% {
      clip-path: inset(60% 0 20% 0);
      transform: translate(3px, -3px);
    }
    25% {
      clip-path: inset(10% 0 70% 0);
      transform: translate(-4px, 1px);
    }
    50% {
      clip-path: inset(80% 0 10% 0);
      transform: translate(2px, -2px);
    }
    75% {
      clip-path: inset(30% 0 50% 0);
      transform: translate(-1px, 3px);
    }
    100% {
      clip-path: inset(0% 0 100% 0);
      transform: translate(0);
      opacity: 0;
    }
  }

  @keyframes drift {
    0% {
      transform: translate(0, 0) scale(1);
    }
    100% {
      transform: translate(10%, 10%) scale(1.1);
    }
  }

  .hero p {
    font-size: 1.5rem;
    max-width: 600px;
    margin-bottom: 4rem;
    font-weight: 500;
  }

  .cycle-wrap {
    display: inline-block;
    background: var(--yellow);
    color: var(--black);
    padding: 4px 12px;
    border-radius: 4px;
    vertical-align: baseline;
    line-height: normal;
  }

  .cycle-word {
    font-weight: 800;
  }

  .hero-actions {
    display: flex;
    gap: 2rem;
  }

  .social-proof {
    margin-top: 2rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #888;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .social-proof span {
    color: var(--black);
    font-weight: 800;
  }

  /* Hover Indicator */
  .hover-indicator {
    position: absolute;
    top: -20px;
    right: 5%;
    display: flex;
    align-items: center;
    gap: 8px;
    animation: bounce 2s ease-in-out infinite;
    z-index: 1000;
    pointer-events: none;
  }

  .hover-arrow {
    font-size: 1.8rem;
    color: var(--yellow);
    transform: rotate(-45deg);
    animation: arrowPoint 2s ease-in-out infinite;
  }

  .hover-text {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--black);
    background: var(--yellow);
    padding: 4px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transform: rotate(-8deg);
    box-shadow: 2px 2px 0 var(--pink);
    white-space: nowrap;
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes arrowPoint {
    0%, 100% {
      transform: rotate(-45deg) translateX(0);
    }
    50% {
      transform: rotate(-45deg) translateX(8px);
    }
  }

  /* Hide indicator after user hovers */
  .hover-indicator.hidden {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  @media (max-width: 768px) {
    .hero {
      padding-block: clamp(80px, 20vw, 120px) clamp(60px, 15vw, 100px);
      text-align: center;
      height: auto;
      min-height: 100vh;
    }

    .hero h1 {
      font-size: clamp(42px, 12vw, 72px);
      line-height: 1.05;
      min-height: auto;
      margin-bottom: 1.5rem;
    }

    .hero p {
      font-size: clamp(16px, 4vw, 22px);
      margin: 0 auto 3rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
      gap: 12px;
      width: 100%;
    }

    .hero-actions .magnet-wrap,
    .hero-actions a {
      width: 100%;
      max-width: 320px;
    }

    .social-proof {
      justify-content: center;
      margin-top: 3rem;
    }

    .hero-blob {
      transform: scale(0.5);
      opacity: 0.04 !important;
    }

    /* Hide hover indicator on mobile */
    .hover-indicator {
      display: none;
    }

    /* Reduce glitch aggressiveness on mobile */
    @keyframes glitch-1 {
      0% {
        clip-path: inset(20% 0 60% 0);
        transform: translate(-2px, 1px);
      }
      20% {
        clip-path: inset(70% 0 10% 0);
        transform: translate(1.5px, -1px);
      }
      100% {
        clip-path: inset(0% 0 100% 0);
        transform: translate(0);
        opacity: 0;
      }
    }
    @keyframes glitch-2 {
      0% {
        clip-path: inset(60% 0 20% 0);
        transform: translate(1.5px, -1.5px);
      }
      25% {
        clip-path: inset(10% 0 70% 0);
        transform: translate(-2px, 0.5px);
      }
      100% {
        clip-path: inset(0% 0 100% 0);
        transform: translate(0);
        opacity: 0;
      }
    }
  }
</style>

<script src="../scripts/glitch.js"></script>
<script src="../scripts/scramble.js"></script>
<script src="../scripts/cycling.js"></script>
<script src="../scripts/hero-blobs.js"></script>
