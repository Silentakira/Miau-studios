---
import BaseLayout from '../layouts/BaseLayout.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import WhyPlay from '../components/WhyPlay.astro';
import Game from '../components/Game.astro';
import Team from '../components/Team.astro';
import Blog from '../components/Blog.astro';
import Community from '../components/Community.astro';
import Footer from '../components/Footer.astro';
import SoundToggle from '../components/SoundToggle.astro';
import CursorGlow from '../components/CursorGlow.astro';
---

<BaseLayout title="Miau Studio | Skate Beats">
  <LoadingScreen />
  <CursorGlow />
  <Nav />
  
  <main>
    <Hero />
    <About />
    <WhyPlay />
    <Game />
    <Team />
    <Blog />
    <Community />
  </main>

  <Footer />
  <SoundToggle />

  <script src="../scripts/scroll.js"></script>
  <script src="../scripts/magnetic.js"></script>
</BaseLayout>

<style>
  main {
    position: relative;
    z-index: 1;
  }
</style>
